{
	"compilerOptions": {
		"lib": ["es2019", "dom"],
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./dist",
		"strict": true,
		"target": "es2019",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["credentials/**/*", "nodes/**/*"],
	"exclude": ["node_modules", "dist"]
}
